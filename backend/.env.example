# Backend Environment Variables
# Copy to .env and fill in your values. Never commit .env.

# Database (Supabase PostgreSQL)
DATABASE_URL=postgresql://user:pass@host:port/db

# Server
PORT=3001
NODE_ENV=development

# CORS — comma-separated allowed origins (admin dashboard URL)
ALLOWED_ORIGINS=https://your-admin.vercel.app

# Admin auth
ADMIN_SECRET=your-secure-random-string-min-16-chars
ADMIN_EMAILS=admin@example.com,other@example.com
ADMIN_DASHBOARD_URL=https://your-admin.vercel.app

# Supabase (auth + storage)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...
SUPABASE_STORAGE_BUCKET=site-uploads

# OpenAI
OPENAI_API_KEY=sk-...

# Stripe
STRIPE_SECRET_KEY=sk-...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID_MONTHLY=price_...
STRIPE_PRICE_ID_PRO=price_...
STRIPE_PRICE_ID_AGENCY=price_...
STRIPE_PRODUCT_ID=prod_...
FRONTEND_URL=https://your-admin.vercel.app

# Email (Resend)
RESEND_API_KEY=re_...
EMAIL_FROM=ChattyBot <leads@yourdomain.com>
LEAD_NOTIFICATION_EMAIL=your-email@domain.com
REPLY_TO=your-email@domain.com

# Twilio (optional)
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_PHONE_NUMBER=+15551234567
TWILIO_WHATSAPP_NUMBER=+15551234567
TWILIO_DEFAULT_SITE_ID=uuid-of-default-site

# Ingestion
INGEST_MAX_PAGES=150
INGEST_CONCURRENCY=3
