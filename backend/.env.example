# Database (Supabase PostgreSQL with pgvector)
# Get this from: Supabase Dashboard → Settings → Database → URI
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres

# OpenAI API Key
# Get this from: platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-...

# Server
PORT=3001
NODE_ENV=production

# CORS — comma-separated list of allowed admin/widget origins
ALLOWED_ORIGINS=https://your-admin.vercel.app

# Admin auth token — minimum 16 characters, treat like a password
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_SECRET=generate-a-strong-random-secret-here
