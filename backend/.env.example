# Database (Supabase PostgreSQL with pgvector)
# Get this from: Supabase Dashboard → Settings → Database → URI
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres

# OpenAI API Key
# Get this from: platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-...

# Server
PORT=3001
NODE_ENV=production

# CORS — comma-separated list of allowed admin/widget origins
ALLOWED_ORIGINS=https://your-admin.vercel.app

# Admin auth token — minimum 16 characters, treat like a password
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_SECRET=generate-a-strong-random-secret-here

# Ingestion limits (Render-safe defaults)
# Maximum pages Playwright will crawl per ingestion job.
INGEST_MAX_PAGES=10

# Supabase Storage (for file-based knowledge base uploads)
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY
SUPABASE_STORAGE_BUCKET=site-uploads

# Optional: SMTP email notifications for leads
# If configured and a site has raffy_overrides.notifications.lead_email set,
# POST /lead will send an email notification (lead still saves even if email fails).
SMTP_HOST=smtp.yourprovider.com
SMTP_PORT=587
SMTP_USER=your_smtp_username
SMTP_PASS=your_smtp_password
SMTP_FROM="ChattyBot <no-reply@yourdomain.com>"
