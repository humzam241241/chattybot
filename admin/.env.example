# Admin Dashboard Environment Variables
# Copy to .env and fill in your values. Never commit .env.

# Backend API — server-side only
API_URL=https://your-backend.onrender.com
ADMIN_SECRET=your-secret-must-match-backend

# Admin dashboard URL (for Stripe redirects)
NEXT_PUBLIC_APP_URL=https://your-admin.vercel.app

# Supabase Auth (required for sign-in/sign-up)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Admin emails — comma-separated; these users get admin access when logged in
NEXT_PUBLIC_ADMIN_EMAILS=admin@example.com

# Public URLs (shown in embed code)
NEXT_PUBLIC_WIDGET_URL=https://your-widget.vercel.app/widget.js
NEXT_PUBLIC_API_URL=https://your-backend.onrender.com
