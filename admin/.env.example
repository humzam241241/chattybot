# Backend API URL — server-side only, NOT prefixed with NEXT_PUBLIC_
# This means it stays on the server and is never sent to the browser
API_URL=https://chattybot-backend.onrender.com

# Admin secret — must match ADMIN_SECRET in backend .env
# Server-side only — never visible to browser
ADMIN_SECRET=your-secret-here

# These two are public-facing URLs shown in embed code — safe to expose to browser
NEXT_PUBLIC_WIDGET_URL=https://chattybot-widget.vercel.app/widget.js
NEXT_PUBLIC_API_URL=https://chattybot-backend.onrender.com
